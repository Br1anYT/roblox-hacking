-- TAB MANAGEMENT SYSTEM
-- ============================================================

local tabs        = {}   -- array of tab data tables
local activeTabId = nil  -- currently selected tab's id
local tabCounter  = 0    -- unique id counter

--[[
    Tab data structure:
    {
        id        : number   - unique identifier
        name      : string   - display name
        content   : string   - the TextBox content
        sideBtn   : Frame    - the sidebar button widget
        page      : Frame    - the editor content page
        textBox   : TextBox  - the code-editing TextBox
    }
--]]

--- Returns a tab by id, or nil
local function GetTabById(id)
    for _, t in ipairs(tabs) do
        if t.id == id then return t end
    end
    return nil
end

--- Rebuilds sidebar button LayoutOrder / search filter
local function RefreshSidebar(filter)
    filter = (filter or ""):lower()
    local order = 1
    for _, t in ipairs(tabs) do
        if t.sideBtn then
            local visible = filter == "" or t.name:lower():find(filter, 1, true)
            t.sideBtn.Visible     = visible ~= nil
            t.sideBtn.LayoutOrder = order
            order += 1
        end
    end
    -- Update empty state
    EmptyLabel.Visible = #tabs == 0
end

--- Switches the active tab with a smooth crossfade
local function SwitchTab(id)
    if activeTabId == id then return end

    -- Hide current
    if activeTabId then
        local old = GetTabById(activeTabId)
        if old and old.page then
            Tween(old.page, TWEEN_FAST, { BackgroundTransparency = 1 })
            old.page.Visible = false
        end
        if old and old.sideBtn then
            Tween(old.sideBtn, TWEEN_FAST, { BackgroundColor3 = Theme.TabInactive })
            local lbl = old.sideBtn:FindFirstChildWhichIsA("TextLabel")
            if lbl then Tween(lbl, TWEEN_FAST, { TextColor3 = Theme.TextSecondary }) end
        end
    end

    activeTabId = id
    local tab = GetTabById(id)
    if not tab then
        HeaderTabName.Text = "No Tab Selected"
        return
    end

    -- Show new tab
    tab.page.Visible = true
    tab.page.BackgroundTransparency = 1
    Tween(tab.page, TWEEN_MED, { BackgroundTransparency = 0 })

    -- Highlight sidebar button
    if tab.sideBtn then
        Tween(tab.sideBtn, TWEEN_FAST, { BackgroundColor3 = Theme.TabActive })
        local lbl = tab.sideBtn:FindFirstChildWhichIsA("TextLabel")
        if lbl then Tween(lbl, TWEEN_FAST, { TextColor3 = Theme.TextPrimary }) end
    end

    HeaderTabName.Text = "  " .. tab.name
    EmptyLabel.Visible = false

    Notify("Tab Opened", "Switched to: " .. tab.name, "info", 2)
end

--- Renames a tab (double-click on sidebar button triggers this)
local function RenameTab(id)
    local tab = GetTabById(id)
    if not tab then return end

    -- Build a small rename popup over the sidebar button
    local overlay = Instance.new("Frame")
    overlay.Size             = UDim2.new(1, 0, 1, 0)
    overlay.BackgroundColor3 = Theme.Overlay
    overlay.BackgroundTransparency = 0.3
    overlay.ZIndex           = 100
    overlay.Parent           = ScreenGui
    Corner(0, overlay)

    local popup = Instance.new("Frame")
    popup.Size             = UDim2.new(0, 300, 0, 100)
    popup.Position         = UDim2.new(0.5, -150, 0.5, -50)
    popup.BackgroundColor3 = Theme.Surface
    popup.BorderSizePixel  = 0
    popup.ZIndex           = 101
    popup.Parent           = ScreenGui
    Corner(12, popup)
    Stroke(Theme.Accent, 1.5, popup)

    MakeLabel({
        Text      = "Rename Tab",
        Font      = Enum.Font.GothamBold,
        Color     = Theme.TextPrimary,
        Size      = 14,
        FrameSize = UDim2.new(1, 0, 0, 36),
        ZIndex    = 102,
        Parent    = popup,
        XAlign    = Enum.TextXAlignment.Center,
        YAlign    = Enum.TextYAlignment.Center,
    })

    local inp = Instance.new("TextBox")
    inp.Size             = UDim2.new(1, -20, 0, 32)
    inp.Position         = UDim2.new(0, 10, 0, 38)
    inp.BackgroundColor3 = Theme.SurfaceAlt
    inp.Text             = tab.name
    inp.TextColor3       = Theme.TextPrimary
    inp.Font             = Enum.Font.Gotham
    inp.TextSize         = 13
    inp.BorderSizePixel  = 0
    inp.ZIndex           = 102
    inp.ClearTextOnFocus = false
    inp.Parent           = popup
    Corner(8, inp)
    Stroke(Theme.Stroke, 1, inp)
    inp:CaptureFocus()

    local function confirm()
        local newName = inp.Text:match("^%s*(.-)%s*$") -- trim whitespace
        if newName and #newName > 0 then
            tab.name = newName
            -- Update sidebar label
            local lbl = tab.sideBtn:FindFirstChild("TabNameLabel")
            if lbl then lbl.Text = newName end
            if activeTabId == id then
                HeaderTabName.Text = "  " .. newName
            end
            Notify("Tab Renamed", "New name: " .. newName, "success", 2)
        end
        overlay:Destroy()
        popup:Destroy()
    end

    inp.FocusLost:Connect(function(enterPressed)
        if enterPressed then confirm() end
    end)

    -- Confirm button
    local confirmBtn = Instance.new("TextButton")
    confirmBtn.Size             = UDim2.new(1, -20, 0, 0)  -- auto height via padding
    confirmBtn.Position         = UDim2.new(0, 10, 1, -4)
    confirmBtn.BackgroundTransparency = 1
    confirmBtn.Text             = ""
    confirmBtn.ZIndex           = 102
    confirmBtn.Parent           = popup

    -- Click outside to cancel
    overlay.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            overlay:Destroy()
            popup:Destroy()
        end
    end)
end

--- Closes/removes a tab
local function CloseTab(id)
    local tabIndex = nil
    for i, t in ipairs(tabs) do
        if t.id == id then tabIndex = i break end
    end
    if not tabIndex then return end

    local tab = tabs[tabIndex]
    local tabName = tab.name

    -- Clean up GUI
    if tab.sideBtn then tab.sideBtn:Destroy() end
    if tab.page    then tab.page:Destroy()    end

    table.remove(tabs, tabIndex)

    -- If we closed the active tab, switch to adjacent
    if activeTabId == id then
        activeTabId = nil
        if #tabs > 0 then
            local nextIdx = math.min(tabIndex, #tabs)
            SwitchTab(tabs[nextIdx].id)
        else
            HeaderTabName.Text = "No Tab Selected"
            EmptyLabel.Visible = true
        end
    end

    RefreshSidebar(SearchBox.Text)
    Notify("Tab Closed", "Removed: " .. tabName, "warning", 2)
end

--- Creates a brand new tab
local function CreateTab(name)
    tabCounter += 1
    local id     = tabCounter
    name = name or ("Tab " .. id)

    -- ── SIDEBAR BUTTON ─────────────────────────────────────
    local sideBtn = Instance.new("Frame")
    sideBtn.Size             = UDim2.new(1, -4, 0, 34)
    sideBtn.BackgroundColor3 = Theme.TabInactive
    sideBtn.BorderSizePixel  = 0
    sideBtn.ZIndex           = 12
    sideBtn.LayoutOrder      = tabCounter
    sideBtn.Parent           = TabListFrame
    Corner(8, sideBtn)

    -- Hover effect
    sideBtn.MouseEnter:Connect(function()
        if activeTabId ~= id then
            Tween(sideBtn, TWEEN_FAST, { BackgroundColor3 = Theme.TabHover })
        end
    end)
    sideBtn.MouseLeave:Connect(function()
        if activeTabId ~= id then
            Tween(sideBtn, TWEEN_FAST, { BackgroundColor3 = Theme.TabInactive })
        end
    end)

    -- Icon dot
    local dot = Instance.new("Frame")
    dot.Size             = UDim2.new(0, 6, 0, 6)
    dot.Position         = UDim2.new(0, 10, 0.5, -3)
    dot.BackgroundColor3 = Theme.AccentDim
    dot.BorderSizePixel  = 0
    dot.ZIndex           = 13
    dot.Parent           = sideBtn
    Corner(3, dot)

    -- Tab name label
    local nameLabel = MakeLabel({
        Text      = name,
        Font      = Enum.Font.Gotham,
        Color     = Theme.TextSecondary,
        Size      = 12,
        FrameSize = UDim2.new(1, -52, 1, 0),
        Position  = UDim2.new(0, 24, 0, 0),
        ZIndex    = 13,
        Parent    = sideBtn,
        XAlign    = Enum.TextXAlignment.Left,
        Truncate  = Enum.TextTruncate.AtEnd,
    })
    nameLabel.Name = "TabNameLabel"

    -- Close (×) button on sidebar entry
    local sideClose = Instance.new("TextButton")
    sideClose.Size             = UDim2.new(0, 22, 0, 22)
    sideClose.Position         = UDim2.new(1, -26, 0.5, -11)
    sideClose.BackgroundColor3 = Theme.SurfaceAlt
    sideClose.Text             = "✕"
    sideClose.TextColor3       = Theme.TextMuted
    sideClose.Font             = Enum.Font.GothamBold
    sideClose.TextSize         = 10
    sideClose.BorderSizePixel  = 0
    sideClose.ZIndex           = 14
    sideClose.Parent           = sideBtn
    Corner(5, sideClose)
    sideClose.BackgroundTransparency = 1
    sideClose.MouseEnter:Connect(function()
        Tween(sideClose, TWEEN_FAST, { BackgroundTransparency = 0, TextColor3 = Theme.Danger })
    end)
    sideClose.MouseLeave:Connect(function()
        Tween(sideClose, TWEEN_FAST, { BackgroundTransparency = 1, TextColor3 = Theme.TextMuted })
    end)
    sideClose.MouseButton1Click:Connect(function()
        CloseTab(id)
    end)

    -- Click to select tab / double-click to rename
    local lastClick = 0
    local clickDetector = Instance.new("TextButton")
    clickDetector.Size             = UDim2.new(1, -28, 1, 0)
    clickDetector.BackgroundTransparency = 1
    clickDetector.Text             = ""
    clickDetector.ZIndex           = 13
    clickDetector.Parent           = sideBtn

    clickDetector.MouseButton1Click:Connect(function()
        local now = tick()
        if now - lastClick < 0.35 then
            -- Double-click: rename
            RenameTab(id)
        else
            -- Single-click: switch
            SwitchTab(id)
        end
        lastClick = now
    end)

    -- ── CONTENT PAGE ───────────────────────────────────────
    local page = Instance.new("Frame")
    page.Name             = "TabPage_" .. id
    page.Size             = UDim2.new(1, 0, 1, 0)
    page.BackgroundColor3 = Theme.Panel
    page.BackgroundTransparency = 1
    page.BorderSizePixel  = 0
    page.Visible          = false
    page.ZIndex           = 11
    page.Parent           = TabContentHolder

    -- Line number gutter
    local Gutter = Instance.new("Frame")
    Gutter.Size             = UDim2.new(0, 36, 1, 0)
    Gutter.BackgroundColor3 = Theme.SurfaceAlt
    Gutter.BorderSizePixel  = 0
    Gutter.ZIndex           = 12
    Gutter.Parent           = page
    Corner(8, Gutter)
    -- Line number label (static decoration)
    local gutterText = ""
    for i = 1, 40 do
        gutterText = gutterText .. tostring(i) .. "\n"
    end
    MakeLabel({
        Text      = gutterText,
        Font      = Enum.Font.Code,
        Color     = Theme.TextMuted,
        Size      = 11,
        FrameSize = UDim2.new(1, 0, 1, 0),
        ZIndex    = 13,
        Parent    = Gutter,
        XAlign    = Enum.TextXAlignment.Center,
        YAlign    = Enum.TextYAlignment.Top,
    })

    -- Actual editable text area
    local textBox = Instance.new("TextBox")
    textBox.Size             = UDim2.new(1, -44, 1, 0)
    textBox.Position         = UDim2.new(0, 44, 0, 0)
    textBox.BackgroundColor3 = Theme.Background
    textBox.Text             = "-- " .. name .. "\n-- Double-click the tab name to rename\n-- Type your script notes here...\n\n"
    textBox.TextColor3       = Theme.TextPrimary
    textBox.Font             = Enum.Font.Code
    textBox.TextSize         = 13
    textBox.TextXAlignment   = Enum.TextXAlignment.Left
    textBox.TextYAlignment   = Enum.TextYAlignment.Top
    textBox.MultiLine        = true
    textBox.ClearTextOnFocus = false
    textBox.BorderSizePixel  = 0
    textBox.ZIndex           = 12
    textBox.TextWrapped      = false
    textBox.Parent           = page
    Corner(8, textBox)
    Stroke(Theme.Stroke, 1, textBox)

    -- Update header info when cursor moves
    textBox:GetPropertyChangedSignal("CursorPosition"):Connect(function()
        local txt   = textBox.Text
        local pos   = textBox.CursorPosition
        if pos < 0 then return end
        local before = txt:sub(1, pos - 1)
        local lines  = select(2, before:gsub("\n", "\n")) + 1
        local lastNL = before:find("\n[^\n]*$") or 0
        local col    = pos - lastNL
        if activeTabId == id then
            HeaderInfo.Text = "Ln " .. lines .. "  Col " .. col
        end
    end)

    -- ── STORE TAB DATA ─────────────────────────────────────
    local tabData = {
        id      = id,
        name    = name,
        content = "",
        sideBtn = sideBtn,
        page    = page,
        textBox = textBox,
    }
    table.insert(tabs, tabData)
    RefreshSidebar(SearchBox.Text)

    -- Animate the new sidebar button in
    sideBtn.Size = UDim2.new(1, -4, 0, 0)
    Tween(sideBtn, TWEEN_BOUNCE, { Size = UDim2.new(1, -4, 0, 34) })

    -- Switch to the new tab
    SwitchTab(id)

    return tabData
end

