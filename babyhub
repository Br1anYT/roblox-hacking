--- Shows a popup notification
--- @param title  string  - Bold heading
--- @param body   string  - Detail text
--- @param kind   string  - "info" | "success" | "warning" | "danger"
--- @param dur    number  - seconds before auto-dismiss
local function Notify(title, body, kind, dur)
    dur  = dur  or 3.5
    kind = kind or "info"

    local kindColor = ({
        info    = Theme.Accent,
        success = Theme.Success,
        warning = Theme.Warning,
        danger  = Theme.Danger,
    })[kind] or Theme.Accent

    -- Build notification frame
    local nf = Instance.new("Frame")
    nf.Size             = UDim2.new(1, 0, 0, 60)
    nf.BackgroundColor3 = Theme.Surface
    nf.BorderSizePixel  = 0
    nf.ZIndex           = 51
    nf.BackgroundTransparency = 1
    nf.Parent           = NotifHolder
    Corner(10, nf)
    Stroke(kindColor, 1.5, nf)

    -- Colored left stripe
    local stripe = Instance.new("Frame")
    stripe.Size             = UDim2.new(0, 4, 1, -16)
    stripe.Position         = UDim2.new(0, 8, 0, 8)
    stripe.BackgroundColor3 = kindColor
    stripe.BorderSizePixel  = 0
    stripe.ZIndex           = 52
    stripe.Parent           = nf
    Corner(2, stripe)

    local nt = MakeLabel({
        Text      = title,
        Font      = Enum.Font.GothamBold,
        Color     = Theme.TextPrimary,
        Size      = 13,
        FrameSize = UDim2.new(1, -60, 0, 22),
        Position  = UDim2.new(0, 22, 0, 8),
        ZIndex    = 52,
        Parent    = nf,
        XAlign    = Enum.TextXAlignment.Left,
    })
    local nb = MakeLabel({
        Text      = body,
        Font      = Enum.Font.Gotham,
        Color     = Theme.TextSecondary,
        Size      = 11,
        FrameSize = UDim2.new(1, -60, 0, 18),
        Position  = UDim2.new(0, 22, 0, 30),
        ZIndex    = 52,
        Parent    = nf,
        XAlign    = Enum.TextXAlignment.Left,
        Truncate  = Enum.TextTruncate.AtEnd,
    })

    -- Slide in
    nf.Position = UDim2.new(1, 20, 0, 0)
    Tween(nf, TWEEN_MED, { BackgroundTransparency = 0 })
    Tween(nf, TWEEN_MED, { Position = UDim2.new(0, 0, 0, 0) })

    -- Auto dismiss
    task.delay(dur, function()
        if nf and nf.Parent then
            Tween(nf, TWEEN_MED, { BackgroundTransparency = 1, Position = UDim2.new(1, 20, 0, 0) })
            task.delay(0.3, function()
                if nf and nf.Parent then nf:Destroy() end
            end)
        end
    end)

    return nf
end

