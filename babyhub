--- Creates a UICorner with the given radius
local function Corner(radius, parent)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius)
    c.Parent = parent
    return c
end

--- Creates a UIStroke
local function Stroke(color, thickness, parent)
    local s = Instance.new("UIStroke")
    s.Color     = color
    s.Thickness = thickness
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent    = parent
    return s
end

--- Creates a UIGradient (vertical, two colors)
local function Gradient(c0, c1, rotation, parent)
    local g = Instance.new("UIGradient")
    g.Color    = ColorSequence.new(c0, c1)
    g.Rotation = rotation or 90
    g.Parent   = parent
    return g
end

--- Quick tween wrapper
local function Tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

--- Adds hover color effect to a button-like frame
local function AddHover(obj, normalColor, hoverColor, prop)
    prop = prop or "BackgroundColor3"
    obj.MouseEnter:Connect(function()
        Tween(obj, TWEEN_FAST, {[prop] = hoverColor})
    end)
    obj.MouseLeave:Connect(function()
        Tween(obj, TWEEN_FAST, {[prop] = normalColor})
    end)
end

--- Creates a TextLabel with sensible defaults
local function MakeLabel(props)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Font                   = props.Font      or Enum.Font.GothamBold
    lbl.Text                   = props.Text      or ""
    lbl.TextColor3             = props.Color     or Theme.TextPrimary
    lbl.TextSize               = props.Size      or 14
    lbl.TextXAlignment         = props.XAlign    or Enum.TextXAlignment.Left
    lbl.TextYAlignment         = props.YAlign    or Enum.TextYAlignment.Center
    lbl.TextTruncate           = props.Truncate  or Enum.TextTruncate.None
    lbl.Size                   = props.FrameSize or UDim2.new(1, 0, 1, 0)
    lbl.Position               = props.Position  or UDim2.new(0, 0, 0, 0)
    lbl.ZIndex                 = props.ZIndex    or 1
    lbl.Parent                 = props.Parent
    return lbl
end

--- Creates an ImageLabel
local function MakeImage(props)
    local img = Instance.new("ImageLabel")
    img.BackgroundTransparency = 1
    img.Image                  = props.Image    or ""
    img.Size                   = props.Size     or UDim2.new(1, 0, 1, 0)
    img.Position               = props.Position or UDim2.new(0, 0, 0, 0)
    img.ImageColor3            = props.Color    or Color3.new(1, 1, 1)
    img.ZIndex                 = props.ZIndex   or 1
    img.Parent                 = props.Parent
    return img
end

